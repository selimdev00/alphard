<header class="site-header">
  <div class="site-header__inner">
    <a class="wordmark" href="/" aria-label="Astronomia, на главную">
      <span class="wordmark__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="28" height="28" fill="none">
          <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1" opacity="0.4" />
          <circle cx="16" cy="16" r="4.5" fill="currentColor" />
          <circle cx="29" cy="16" r="2.4" fill="currentColor" />
        </svg>
      </span>
      <span class="wordmark__text">Astronomia</span>
    </a>

    <nav class="switcher" aria-label="Планеты Солнечной системы">
      <ul class="switcher__list">
        <% planets.forEach(function (p) { %>
        <li>
          <a
            class="chip<%= (typeof current !== 'undefined' && current === p.slug) ? ' chip--active' : '' %>"
            href="/planets/<%= p.slug %>"
            style="--accent: <%= p.accent %>"
            <%= (typeof current !== 'undefined' && current === p.slug) ? 'aria-current="page"' : '' %>
          >
            <span class="chip__dot" aria-hidden="true"></span>
            <span class="chip__idx"><%= String(p.index).padStart(2, "0") %></span>
            <span class="chip__name"><%= p.name %></span>
          </a>
        </li>
        <% }); %>
      </ul>
    </nav>
  </div>
</header>
