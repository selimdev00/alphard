<!DOCTYPE html>
<html lang="ru">
  <%- include('config/head') %>
  <body data-page="home">
    <a class="skip-link" href="#main">Перейти к содержимому</a>
    <%- include('components/header', { planets: planets }) %>

    <main id="main">
      <section class="hero" id="hero">
        <div class="hero__grid">
          <p class="eyebrow" data-reveal>Обсерватория в браузере</p>
          <h1 class="hero__title" data-reveal>Astronomia</h1>
          <p class="hero__lede" data-reveal>
            Девять миров Солнечной системы - в трёхмерных моделях, телеметрии и фактах.
            Откройте порт наблюдения и рассмотрите каждую планету вблизи.
          </p>
          <div class="hero__actions" data-reveal>
            <a class="btn btn--primary" href="#index">Смотреть планеты</a>
            <a class="btn btn--ghost" href="/planets/earth">Начать с Земли</a>
          </div>
          <dl class="hero__stats" data-reveal>
            <div><dt>Планет и карликов</dt><dd>09</dd></div>
            <div><dt>Звезда системы</dt><dd>01</dd></div>
            <div><dt>3D-моделей</dt><dd>09</dd></div>
          </dl>
        </div>
        <div class="hero__scroll" aria-hidden="true">
          <span class="mono">scroll</span>
          <span class="hero__scroll-line"></span>
        </div>
      </section>

      <section class="index-section" id="index" aria-labelledby="index-heading">
        <div class="section-head">
          <p class="eyebrow" data-reveal>Орбитальный индекс</p>
          <h2 id="index-heading" data-reveal>Исследуйте планеты</h2>
          <p class="section-head__sub" data-reveal>
            От раскалённого Меркурия до ледяного Плутона. Наведите курсор, чтобы зажечь
            порт наблюдения, и откройте мир целиком.
          </p>
        </div>

        <ul class="planet-grid" role="list">
          <% planets.forEach(function (p) { %>
          <li>
            <a class="planet-card" href="/planets/<%= p.slug %>" style="--accent: <%= p.accent %>" data-reveal>
              <div class="obs-port">
                <model-viewer
                  class="obs-port__model"
                  src="/images/planets/<%= p.modelName %>"
                  alt="Трёхмерная модель планеты <%= p.name %>"
                  auto-rotate
                  rotation-per-second="12deg"
                  interaction-prompt="none"
                  disable-zoom
                  loading="lazy"
                  reveal="auto"
                  style="background: transparent"
                ></model-viewer>
                <span class="obs-port__skeleton" aria-hidden="true"></span>
                <span class="obs-port__caption mono" aria-hidden="true">
                  <span><%= p.slug.toUpperCase() %></span>
                  <span>OBS · <%= String(p.index).padStart(2, "0") %></span>
                </span>
                <% if (p.notAPlanet) { %>
                <span class="badge">Карликовая планета</span>
                <% } %>
              </div>
              <div class="planet-card__body">
                <span class="planet-card__idx mono"><%= String(p.index).padStart(2, "0") %></span>
                <h3 class="planet-card__name"><%= p.name %></h3>
                <p class="planet-card__tagline"><%= p.tagline %></p>
                <span class="planet-card__group mono"><%= p.group %></span>
              </div>
            </a>
          </li>
          <% }); %>
        </ul>
      </section>
    </main>

    <%- include('components/footer') %>
  </body>
</html>
